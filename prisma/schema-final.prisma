generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

generator client_default {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model UnitKerja {
  id                 Int                  @id @default(autoincrement())
  nama               String               @unique
  kode               String               @unique
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  sasarans           Sasaran[]
  kegiatans          Kegiatan[]
  identifikasiRisiko IdentifikasiRisiko[]
}

model Kegiatan {
  id                 Int                  @id @default(autoincrement())
  nama               String
  deskripsi          String?
  unitKerjaId        Int?
  sasaranId          Int?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  unitKerja          UnitKerja?           @relation(fields: [unitKerjaId], references: [id], onDelete: SetNull)
  sasaran            Sasaran?             @relation(fields: [sasaranId], references: [id], onDelete: SetNull)
  prosesBisnis       ProsesBisnis[]
  identifikasiRisiko IdentifikasiRisiko[]
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     String // Email or user identifier
  userName   String
  action     String // CREATE, UPDATE, DELETE, VIEW, LOGIN, LOGOUT, etc.
  resource   String // Resource name (e.g., "Sasaran", "RisikoActual", etc.)
  resourceId String? // ID of the affected resource
  details    Json? // Additional details about the action
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([timestamp])
}

model Sasaran {
  id        Int      @id @default(autoincrement())
  nama      String
  deskripsi String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProsesBisnis {
  id        Int      @id @default(autoincrement())
  nama      String
  deskripsi String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PemangkuKepentingan {
  id        Int      @id @default(autoincrement())
  nama      String
  deskripsi String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PeraturanPerundangan {
  id        Int      @id @default(autoincrement())
  nama      String
  deskripsi String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JenisRisiko {
  id                  Int                  @id @default(autoincrement())
  nama                String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  identifikasiRisikos IdentifikasiRisiko[]
}

model SumberRisiko {
  id                  Int                  @id @default(autoincrement())
  nama                String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  identifikasiRisikos IdentifikasiRisiko[]
}

model KategoriRisiko {
  id                   Int                   @id @default(autoincrement())
  nama                 String
  deskripsi            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  kriteriaKemungkinans KriteriaKemungkinan[]
  seleraRisikos        SeleraRisiko[]
  identifikasiRisikos  IdentifikasiRisiko[]
}

model AreaDampak {
  id                  Int                  @id @default(autoincrement())
  nama                String
  deskripsi           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  identifikasiRisikos IdentifikasiRisiko[]
}

model LevelKemungkinan {
  id                            Int                     @id @default(autoincrement())
  nama                          String
  skala                         Int
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt
  kriteriaKemungkinans          KriteriaKemungkinan[]
  analisisRisikos               AnalisisRisiko[]
  rencanaPenangananKemungkinans RencanaPenanganan[]
  matriksAnalisisRisikos        MatriksAnalisisRisiko[]
}

model LevelDampak {
  id                       Int                     @id @default(autoincrement())
  nama                     String
  skala                    Int                     @default(1)
  deskripsi                String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  analisisRisikos          AnalisisRisiko[]
  rencanaPenangananDampaks RencanaPenanganan[]
  matriksAnalisisRisikos   MatriksAnalisisRisiko[]
}

model LevelRisiko {
  id                     Int                     @id @default(autoincrement())
  nama                   String
  deskripsi              String?
  rentang                String?
  tindakan               String?
  warna                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  analisisRisikos        AnalisisRisiko[]
  matriksAnalisisRisikos MatriksAnalisisRisiko[]
}

model OpsiPenanganan {
  id        Int      @id @default(autoincrement())
  nama      String
  deskripsi String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KriteriaKemungkinan {
  id                    Int              @id @default(autoincrement())
  kategoriRisikoId      Int
  kategoriRisiko        KategoriRisiko   @relation(fields: [kategoriRisikoId], references: [id])
  levelKemungkinanId    Int
  levelKemungkinan      LevelKemungkinan @relation(fields: [levelKemungkinanId], references: [id])
  persentaseKemungkinan Int
  deskripsi             String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model Kri {
  id                   Int                 @id @default(autoincrement())
  namaIndikator        String
  deskripsi            String?
  batasHijau           Float?
  batasKuning          Float?
  batasMerah           Float?
  nilaiAktual          Float?
  frekuensiPemantauan  String?
  identifikasiRisikoId Int?
  identifikasiRisiko   IdentifikasiRisiko? @relation(fields: [identifikasiRisikoId], references: [id])
  penanggungJawab      String?
  targetNilaiHarapan   Float?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model KriteriaDampak {
  id        Int      @id @default(autoincrement())
  nama      String
  deskripsi String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeleraRisiko {
  id                   Int            @id @default(autoincrement())
  kategoriRisikoId     Int
  kategoriRisiko       KategoriRisiko @relation(fields: [kategoriRisikoId], references: [id])
  besaranRisikoMinimum Int
  deskripsi            String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

model IdentifikasiRisiko {
  id                Int                @id @default(autoincrement())
  risiko            String
  jenisRisikoId     Int
  jenisRisiko       JenisRisiko        @relation(fields: [jenisRisikoId], references: [id])
  sumberRisikoId    Int
  sumberRisiko      SumberRisiko       @relation(fields: [sumberRisikoId], references: [id])
  kategoriRisikoId  Int
  kategoriRisiko    KategoriRisiko     @relation(fields: [kategoriRisikoId], references: [id])
  areaDampakId      Int
  areaDampak        AreaDampak         @relation(fields: [areaDampakId], references: [id])
  penyebab          String?
  dampak            String?
  kegiatanId         Int?
  unitKerjaId         Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  analisisRisiko    AnalisisRisiko?
  evaluasiRisiko    EvaluasiRisiko?
  rencanaPenanganan RencanaPenanganan?
  kris              Kri[]
}

model AnalisisRisiko {
  id                      Int                @id @default(autoincrement())
  identifikasiRisikoId    Int                @unique
  identifikasiRisiko      IdentifikasiRisiko @relation(fields: [identifikasiRisikoId], references: [id])
  levelKemungkinanId      Int?
  levelKemungkinan        LevelKemungkinan?  @relation(fields: [levelKemungkinanId], references: [id])
  levelDampakId           Int?
  levelDampak             LevelDampak?       @relation(fields: [levelDampakId], references: [id])
  levelRisikoId           Int?
  levelRisiko             LevelRisiko?       @relation(fields: [levelRisikoId], references: [id])
  pengendalianUraian      String?
  pengendalianEfektivitas String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
}

model EvaluasiRisiko {
  id                   Int                @id @default(autoincrement())
  identifikasiRisikoId Int                @unique
  identifikasiRisiko   IdentifikasiRisiko @relation(fields: [identifikasiRisikoId], references: [id])
  responRisiko         String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model RencanaPenanganan {
  id                         Int                @id @default(autoincrement())
  identifikasiRisikoId       Int                @unique
  identifikasiRisiko         IdentifikasiRisiko @relation(fields: [identifikasiRisikoId], references: [id])
  jenisPenanganan            String?
    rencanaTidakPenanganan     String?
  targetOutput               String?
  targetWaktu                String?
  penanggungJawab            String?
  residualLevelKemungkinanId Int?
  residualLevelKemungkinan   LevelKemungkinan?  @relation(fields: [residualLevelKemungkinanId], references: [id])
  residualLevelDampakId      Int?
  residualLevelDampak        LevelDampak?       @relation(fields: [residualLevelDampakId], references: [id])
  keterjadiRisiko            String?
    realisasiWaktu             String?
  realisasiOutput            String?
  dokumenPendukung           String?
  persetujuan                String?
  disetujuiOleh              String?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
}

model MatriksAnalisisRisiko {
  id                 Int              @id @default(autoincrement())
  levelKemungkinanId Int
  levelKemungkinan   LevelKemungkinan @relation(fields: [levelKemungkinanId], references: [id])
  levelDampakId      Int
  levelDampak        LevelDampak      @relation(fields: [levelDampakId], references: [id])
  besaran            Int
  levelRisikoId      Int
  levelRisiko        LevelRisiko      @relation(fields: [levelRisikoId], references: [id])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model User {
  id          Int              @id @default(autoincrement())
  email       String           @unique
  name        String
  roleId      Int
  role        Role             @relation(fields: [roleId], references: [id])
  password    String           @default("password")
  permissions UserPermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id        Int              @id @default(autoincrement())
  resource  String // e.g. "sasaran", "users", etc.
  action    String // "create", "read", "update", "delete"
  roles     RolePermission[]
  users     UserPermission[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([resource, action])
}

model RolePermission {
  roleId       Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserPermission {
  userId       Int
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  value        String // "grant" or "deny"

  @@id([userId, permissionId])
}
